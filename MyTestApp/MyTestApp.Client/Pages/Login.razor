@page "/login"
@rendermode InteractiveWebAssembly

@layout MyTestApp.Client.Layout.LoginLayout
@using MyTestApp.Models

@inject HttpClient httpClient
@inject CustomAuthenticationStateProvider customAuthenticationStateProvider
@inject NavigationManager navigationManager
@inject IHttpClientFactory httpClientFactory


<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center pt-10">
  <MudCard Elevation="20" Class="pa-6" Style="width: 100%;">
    <MudCardHeader>
      <MudText Typo="Typo.h4" Align="Align.Center">Hesabınıza Giriş Yapın</MudText>
    </MudCardHeader>
    <MudCardContent>
      <MudForm @ref="form" @bind-IsValid="@success" @bind-Errors="@errors" Model="LoginModelObject">
        <MudTextField T="string" Label="E-posta Adresi" Required="true" InputType="InputType.Email" Immediate="true" @bind-Value="LoginModelObject.Mail" />
        <MudTextField T="string" Label="Şifre" Required="true" InputType="InputType.Password" Class="mt-3" @bind-Value="LoginModelObject.Password" />

        <div class="d-flex justify-space-between pt-4">
          <MudCheckBox T="bool" Label="Beni Hatırla" />
          <MudLink Href="/forgotpassword" Typo="Typo.subtitle2">Şifremi Unuttum</MudLink>
        </div>

        <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6" OnClick="MySubmitVoid">
          Giriş Yap
        </MudButton>
      </MudForm>

      @if (errors?.Length > 0)
      {
        <div class="mt-4">
          @foreach (var e in errors)
          {
            <MudText Color="Color.Error">@e</MudText>
          }
        </div>
      }
    </MudCardContent>
    <MudCardActions Class="d-flex justify-center">
      <MudText Typo="Typo.subtitle2">Hesabınız yok mu? <MudLink Href="/register">Kaydolun</MudLink></MudText>
    </MudCardActions>
  </MudCard>
</MudContainer>

@code {
  MudForm form;   
  bool success;
  string[] errors = { };
  public LoginModel LoginModelObject = new LoginModel();

  private async Task MySubmitVoid()
  {
    await form.Validate();

    // Log form validity
    Console.WriteLine($"Form.IsValid = {form.IsValid}");

    if (form.IsValid)
    {
      try
      {
        var client = httpClientFactory.CreateClient("PublicAPI");
        Console.WriteLine("Sending login request to https://localhost:7244/api/Auth/login");
        var response = await client.PostAsJsonAsync("https://localhost:7244/api/Auth/login", LoginModelObject);

        Console.WriteLine($"Login response status: {(int)response.StatusCode} {response.ReasonPhrase}");

        if (response.IsSuccessStatusCode)
        {
          var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
          if (result is not null)
          {
            // Eğer Token property boşsa bunu burada loglayın
            Console.WriteLine($"Received token length: {result.Token?.Length}");
            customAuthenticationStateProvider.MarkUserAsAuthenticated(result.Token);
            navigationManager.NavigateTo("/");
            return;
          }
          errors = new[] { "Sunucudan beklenen yanıt alınamadı." };
          StateHasChanged();
        }
        else
        {
          var body = await response.Content.ReadAsStringAsync();
          Console.WriteLine($"Login failed. Body: {body}");
          errors = new[] { string.IsNullOrWhiteSpace(body) ? $"Giriş başarısız. Kod: {(int)response.StatusCode}" : body };
          customAuthenticationStateProvider.MarkUserAsLoggedout();
          StateHasChanged();
        }
      }
      catch (Exception ex)
      {
        Console.WriteLine($"Exception during login: {ex}");
        errors = new[] { ex.Message };
        StateHasChanged();
      }
    }
    else
    {
      errors = new[] { "Lütfen tüm alanları doldurun ve formu doğrulayın." };
      StateHasChanged();
    }
  }
}